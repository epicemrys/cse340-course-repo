<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <h2><%= project.title %></h2>

    <p>
        <strong>Date:</strong>
        <%= new Intl.DateTimeFormat('en-US', {
            dateStyle: 'long',
            timeZone: 'UTC'
        }).format(new Date(project.date)) %>
    </p>
    <p><strong>Description:</strong> <%= project.description %></p>
    <p><strong>Location:</strong> <%= project.location %></p>
    <p>
        <strong>Organization:</strong>
        <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
    </p>
    <div class="project-categories">
        <strong>Categories:</strong>
        <% if (categories.length > 0) { %>
            <ul class="category-tags">
                <% categories.forEach(category => { %>
                    <li>
                        <a href="/category/<%= category.category_id %>"><%= category.name %></a>
                    </li>
                <% }); %>
            </ul>
        <% } else { %>
            <span>No categories assigned</span>
        <% } %>
    </div>

    <p><a href="/projects">Back to upcoming service projects</a></p>
</main>

<%- include('partials/footer') %>
